<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer gold ring -->
    <item android:left="10dp" android:top="10dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#FFD700"
                android:centerColor="#FFC107"
                android:endColor="#FFA000"
                android:type="linear"/>
            <stroke android:width="4dp" android:color="#FFB300"/>
        </shape>
    </item>
    <!-- Inner circle -->
    <item android:left="12dp" android:top="12dp" android:right="12dp" android:bottom="12dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#FFC107"
                android:endColor="#FF8F00"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>