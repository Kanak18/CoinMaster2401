<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CoinMaster" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary Colors from SPIN LINK Icon -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_light</item>
        <item name="colorOnPrimary">@color/text_light</item>
        
        <!-- Secondary Colors from SPIN LINK Icon -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/text_light</item>
        
        <!-- Accent Colors from SPIN LINK Icon -->
        <item name="colorAccent">@color/accent</item>
        <item name="colorTertiary">@color/highlight</item>
        <item name="colorOnTertiary">@color/text_primary</item>
        
        <!-- Surface Colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_light</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Container Colors -->
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryContainer</item>
        <item name="colorTertiaryContainer">@color/colorTertiaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        <item name="colorOnTertiaryContainer">@color/text_primary</item>
        
        <!-- Status Bar and Navigation -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        
        <!-- Button Colors -->
        <item name="colorButtonNormal">@color/button_primary</item>
        
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        
        <!-- Ripple Colors -->
        <item name="colorControlHighlight">@color/primary_light</item>
        <item name="colorControlNormal">@color/primary</item>
        
        <!-- Error Colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/text_light</item>
        <item name="colorErrorContainer">@color/error</item>
        <item name="colorOnErrorContainer">@color/text_light</item>
        
        <!-- Outline Colors -->
        <item name="colorOutline">@color/text_secondary</item>
        <item name="colorOutlineVariant">@color/text_secondary</item>
    </style>
</resources>